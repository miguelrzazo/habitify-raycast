{
  "name": "habitify-raycast",
  "title": "Habitify",
  "description": "Manage Habitify habits from Raycast.",
  "version": "0.1.0",
  "private": true,
  "icon": "icon.png",
  "author": "razz13",
  "license": "MIT",
  "platforms": ["macOS"],
  "categories": ["Productivity"],
  "keywords": ["Habitify", "habits", "productivity"],
  "preferences": [
    {
      "name": "apiKey",
      "title": "Habitify API Key",
      "description": "Create it in Habitify Settings > API. Required for all commands.",
      "type": "password",
      "required": true
    }
  ],
  "commands": [
    {
      "name": "index",
      "title": "Today Habits",
      "description": "View and manage today's Habitify habits.",
      "mode": "view"
    }
  ],
  "scripts": {
    "dev": "ray develop",
    "build": "ray build",
    "lint": "ray lint"
  },
  "dependencies": {
    "@raycast/api": "^1.104.19",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
